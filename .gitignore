# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local state (calendar event IDs are unique to your machine)
scripts/state.json
scripts/pr_state.json
scripts/pr_calendar_state.json

# PR-watcher codex runs (raw JSONL transcripts may contain private diffs)
scripts/pr_logs/

# Runtime flock targets (per-PR locks, rerun coalescing markers, state lock)
scripts/locks/
# Legacy global flock — kept here so old checkouts don't accidentally commit it
scripts/pr_watcher.lock

# Auto-generated
MISSING.md

# Logs
logs/*
!logs/.gitkeep

# Personal data — these directories are populated by you locally,
# and the contents stay out of git so the public repo never carries
# names, birthdays, gift records, etc.
people/*
!people/README.md

history/*
!history/README.md

holidays/custom/*
!holidays/custom/README.md

# User-specific generated plists (use install_launchd.sh to regenerate)
com.*.calendar.daily.plist
com.*.calendar.pr-watcher.plist
!com.calendar.daily.plist.template
!com.calendar.pr-watcher.plist.template

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
